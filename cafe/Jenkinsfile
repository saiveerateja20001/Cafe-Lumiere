pipeline {
    agent { label 'node1' }

    options {
        timeout(time: 60, unit: 'MINUTES')
    }

    environment {
        DOCKER_REGISTRY = "docker.io/saiveerateja"
        IMAGE_TAG = "${env.BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Lint') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    //sh 'pip3 install flake8'
                    //sh 'flake8 frontend/ order-service/ kitchen-service/ --max-line-length=120 --ignore=E501,W503 || true'
                }
            }
        }

        stage('Build Images') {
            parallel {

                stage('Build Frontend') {
                    steps {
                        dir('cafe/frontend') {
                            sh "docker build -t ${DOCKER_REGISTRY}/cafe-lumiere-frontend:${IMAGE_TAG} ."
                        }
                    }
                }

                stage('Build Order Service') {
                    steps {
                        dir('cafe/order-service') {
                            sh "docker build -t ${DOCKER_REGISTRY}/cafe-lumiere-order-service:${IMAGE_TAG} ."
                        }
                    }
                }

                stage('Build Kitchen Service') {
                    steps {
                        dir('cafe/kitchen-service') {
                            sh "docker build -t ${DOCKER_REGISTRY}/cafe-lumiere-kitchen-service:${IMAGE_TAG} ."
                        }
                    }
                }

            }
        }

        stage('Security Scan') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {

                    sh "trivy image --exit-code 0 --no-progress --format table ${DOCKER_REGISTRY}/cafe-lumiere-frontend:${IMAGE_TAG}"
                    sh "trivy image --exit-code 0 --no-progress --format table ${DOCKER_REGISTRY}/cafe-lumiere-order-service:${IMAGE_TAG}"
                    sh "trivy image --exit-code 0 --no-progress --format table ${DOCKER_REGISTRY}/cafe-lumiere-kitchen-service:${IMAGE_TAG}"

                    script {
                        def scannerHome = tool 'SonarQubeScanner'
                        withSonarQubeEnv('SonarQube') {
                            sh "${scannerHome}/bin/sonar-scanner"
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Test') {
            steps {
                timeout(time: 15, unit: 'MINUTES') {
                    sh 'docker compose up -d --build'
                    // Add your test command here if needed
                    sh 'docker compose down'
                }
            }
        }

        stage('Push Images') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {

                    withCredentials([usernamePassword(
                        credentialsId: 'docker-registry-creds',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {

                        sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                    }

                    sh "docker push ${DOCKER_REGISTRY}/cafe-lumiere-frontend:${IMAGE_TAG}"
                    sh "docker push ${DOCKER_REGISTRY}/cafe-lumiere-order-service:${IMAGE_TAG}"
                    sh "docker push ${DOCKER_REGISTRY}/cafe-lumiere-kitchen-service:${IMAGE_TAG}"
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                echo "Deploy stage placeholder"
                // Example if you want deployment later:
                // sh "kubectl set image deployment/frontend frontend=${DOCKER_REGISTRY}/cafe-lumiere-frontend:${IMAGE_TAG}"
            }
        }
    }

    post {

        always {
            sh 'docker compose down || true'
            sh 'docker system prune -f'
            cleanWs()
        }

        success {
            echo 'Pipeline succeeded!'
        }

        failure {
            echo 'Pipeline failed!'
        }
    }
}